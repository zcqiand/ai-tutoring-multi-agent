# AI 学习辅导多智能体系统环境变量模板。
#
# 拷贝为 .env 后填值；.env 已在 .gitignore 排除。
# 没有这个 key，run_demo 会立刻报错退出——不会静默用 mock 假装跑通。

# Anthropic API Key（从 https://console.anthropic.com/ 获取）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 可选：指定模型（默认 sonnet-4-6，与 version-lock 一致）
# 复杂规划与评估用 sonnet，简单讲解可降到 haiku 省成本
AI_TUTOR_MODEL_PLANNER=claude-sonnet-4-6
AI_TUTOR_MODEL_TUTOR=claude-sonnet-4-6
AI_TUTOR_MODEL_EVALUATOR=claude-sonnet-4-6

# 可选：单次 demo 硬预算上限（美元）。超出 orchestrator 中止
AI_TUTOR_BUDGET_USD=0.50
